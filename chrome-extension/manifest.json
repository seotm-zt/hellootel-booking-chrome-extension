{
  "manifest_version": 3,
  "name": "Booking Saver",
  "version": "0.3.0",
  "description": "Saves bookings from supported sites to the database.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Booking Saver",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "http://booking.localhost/*",
        "https://booking.localhost/*"
      ],
      "js": [
        "auth.js",
        "parsers/registry.js",
        "parsers/config-engine.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://booking.localhost/admin/extension/page-reports/*",
        "https://booking.localhost/admin/extension/page-reports/*"
      ],
      "js": [
        "auth.js",
        "parsers/registry.js",
        "parsers/config-engine.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
