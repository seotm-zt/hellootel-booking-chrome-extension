{
  "manifest_version": 3,
  "name": "Booking Saver",
  "version": "1.0.0",
  "description": "Saves bookings from supported sites to the database.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://booking-configurator.hellootel.com/*",
    "https://demo.velikolepniy-vek.com/*",
    "https://coralagency.ru/*",
    "https://agency.pegast.ru/MyAccount/Bookings/*"
  ],
  "action": {
    "default_title": "Booking Saver",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://demo.velikolepniy-vek.com/hotel/book/history*",
        "https://coralagency.ru/reservation/search*",
        "https://agency.pegast.ru/*"
      ],
      "js": [
        "auth.js",
        "parsers/currency-utils.js",
        "parsers/registry.js",
        "parsers/config-engine.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://booking-configurator.hellootel.com/admin/extension/page-reports/*"
      ],
      "js": [
        "auth.js",
        "parsers/currency-utils.js",
        "parsers/registry.js",
        "parsers/config-engine.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
